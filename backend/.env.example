# Supabase Project Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...       # Server-side only, never expose to client
SUPABASE_ANON_KEY=eyJhbGciOi...                # Safe for frontend
SUPABASE_JWT_SECRET=                            # Set to your Supabase JWT secret for production

# DeepSeek API (OpenAI-compatible) for AI chat
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Environment (development | production)
ENVIRONMENT=development

# CORS: Comma-separated list of allowed origins (set in production!)
ALLOWED_ORIGINS=http://localhost:5173

# Server port (default 8000, set by Render/Railway via PORT env var)
PORT=8000

# Optional: Local filesystem fallback (ignored when SUPABASE_URL is set)
NOTES_DIR=../notes